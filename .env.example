# MedSync Configuration

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-proj-your-actual-key-here

# Supabase Configuration
# Get these values from your Supabase project settings:
# - Go to https://supabase.com -> Your Project -> Settings -> API
# - SUPABASE_URL is under "Project URL"
# - SUPABASE_SERVICE_ROLE_KEY is under "Service role secret"
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Backend Configuration
MEDSYNC_CHROMA_DIR=./medsync_db
MEDSYNC_COLLECTION=medical_reports
MEDSYNC_UPLOAD_DIR=./uploads
MEDSYNC_CACHE_DIR=./.medsync_cache

# Model Configuration
MEDSYNC_CHAT_MODEL=gpt-4o-mini
MEDSYNC_EMBED_MODEL=text-embedding-3-small

# Optional: Feature Flags
# MEDSYNC_LLM_DISABLED=false
# MEDSYNC_FAITHFULNESS_DISABLED=false

# Optional: Advanced Settings
# MEDSYNC_TEMPERATURE=0
# MEDSYNC_MAX_TOKENS=400
# MEDSYNC_MAX_MEDICAL_TOKENS=1200

# Logging
LOG_LEVEL=INFO

# Backend API Base URL (optional)
# BACKEND_API_BASE_URL=http://localhost:8000

