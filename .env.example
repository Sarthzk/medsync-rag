# MedSync Configuration

# OpenAI API Configuration
OPENAI_API_KEY=your_api_key_here

# Backend Configuration
MEDSYNC_CHROMA_DIR=./medsync_db
MEDSYNC_COLLECTION=medical_reports
MEDSYNC_UPLOAD_DIR=./uploads
MEDSYNC_CACHE_DIR=./.medsync_cache

# Model Configuration
MEDSYNC_CHAT_MODEL=gpt-4o-mini
MEDSYNC_EMBED_MODEL=text-embedding-3-small

# Optional: Feature Flags
# MEDSYNC_LLM_DISABLED=false
# MEDSYNC_FAITHFULNESS_DISABLED=false

# Optional: Advanced Settings
# MEDSYNC_TEMPERATURE=0
# MEDSYNC_MAX_TOKENS=400
# MEDSYNC_MAX_MEDICAL_TOKENS=1200

# Logging
LOG_LEVEL=INFO

# Backend API Base URL (optional)
# BACKEND_API_BASE_URL=http://localhost:8000
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Supabase (Vitals persistence for Vercel)
# Create a `vitals` table in Supabase, then set these in Vercel project env vars.
SUPABASE_URL=https://your-project-ref.supabase.co
# Use the Service Role key on the backend only (never expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
